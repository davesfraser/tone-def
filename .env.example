# Copy this file to .env and fill in real values
# .env is gitignored — never commit credentials or secrets to the repository

# ------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------

# Set to "production" for scheduled or shared runs
# ENVIRONMENT=development

# ------------------------------------------------------------------
# Data access
# ------------------------------------------------------------------

# Example: a database connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Example: an API key for a data vendor
# DATA_VENDOR_API_KEY=your-key-here

# ------------------------------------------------------------------
# Analysis parameters
# ------------------------------------------------------------------

# Override the default significance threshold if needed
# ALPHA=0.05

# Override the minimum sample size floor
# MIN_SAMPLE_SIZE=30
