# Copy this file to .env and fill in real values
# .env is gitignored — never commit credentials or secrets to the repository

# Required — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=

# Path to directory containing Guitar Rig 7 factory presets (.ngrr files)
# Windows default: C:\Program Files\Common Files\Native Instruments\Guitar Rig 7\Rack Presets
# macOS default:   /Library/Application Support/Native Instruments/Guitar Rig 7/Rack Presets
GR7_PRESETS_DIR=

# Runtime environment
# ENVIRONMENT=development
# LOG_LEVEL=INFO

# Reproducibility
# RANDOM_SEED=42

# LLM runtime tuning
# PROVIDER_PRIMARY=anthropic
# DEFAULT_MODEL=anthropic/claude-sonnet-4-5-20250929
# EVAL_JUDGE_MODEL=anthropic/claude-sonnet-4-5-20250929
# EVAL_JUDGE_PINNED=true
# MAX_TOKENS=4096
# TEMPERATURE=0.0
# REQUEST_TIMEOUT_SECONDS=60
# RETRY_MAX_ATTEMPTS=3
# CACHE_ENABLED=true
# CACHE_DIR=cache
# TRACE_ENABLED=false
# TRACE_BACKEND=none
# COST_BUDGET_USD=5.0
# LATENCY_BUDGET_SECONDS=30.0
# PHASE1_TEMPERATURE=0.4
# PHASE2_TEMPERATURE=0.35

# Observability
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LOGFIRE_TOKEN=
# PHOENIX_COLLECTOR_ENDPOINT=

# Exemplar matching weights
# EXEMPLAR_TAG_WEIGHT=0.6
# EXEMPLAR_COMPONENT_WEIGHT=0.4
