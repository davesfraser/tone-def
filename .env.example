# Copy this file to .env and fill in real values
# .env is gitignored — never commit credentials or secrets to the repository

# Required — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Path to directory containing Guitar Rig 7 factory presets (.ngrr files)
# Windows default: C:\Program Files\Common Files\Native Instruments\Guitar Rig 7\Rack Presets
# macOS default:   /Library/Application Support/Native Instruments/Guitar Rig 7/Rack Presets
GR7_PRESETS_DIR=
